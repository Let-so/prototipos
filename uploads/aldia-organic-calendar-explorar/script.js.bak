      ${checkRow("Medicaciones", true)}${checkRow("Estudios", true)}${checkRow("Consultas", true)}
      ${checkRow("Audios y notas", true)}${checkRow("Síntomas mencionados", false)}${checkRow("Preguntas pendientes", true)}
