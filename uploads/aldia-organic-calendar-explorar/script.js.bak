function docRow({ title, meta, color }) {
  return `<button class="row" style="width:100%;background:none;border:none;cursor:pointer;text-align:left;font-family:inherit" data-toast="Abriendo: ${title}">
    <span class="row__icon"><span class="row__icon-bg blob--${color}"></span>${I.doc}</span>
    <div class="row__body"><div class="row__title">${title}</div><div class="row__sub">${meta}</div></div>
    ${I.chevron}
  </button>`;
}

ROUTES.consultas = () => {
  const days = [];
  for (let i = 28; i >= 23; i--) days.push(i); // dows row top placeholders handled below
  return `
  ${topbar({ left:`<button class="iconbtn" data-go="historia" aria-label="Volver">${I.back}</button>`, title:"Consultas",
    right:`<button class="iconbtn" data-toast="Agendar nueva consulta" aria-label="Agendar">${I.calendar}</button>` })}
  <div class="content" style="padding-top:0">
    <div class="cal mb-16">
      <div class="cal__head"><span class="h3">Mayo 2024</span>${I.chevron}</div>
      <div class="cal__grid">
        ${["L","M","M","J","V","S","D"].map(d=>`<span class="cal__dow">${d}</span>`).join("")}
        ${calDays()}
      </div>
    </div>
    <button class="card" style="width:100%;text-align:left;border:none;cursor:pointer" data-go="evento">
      <div class="flex items-center gap-12">
        <div style="text-align:center"><div class="muted" style="font-size:12px">MAY</div><div class="h2">28</div></div>
        <div><div class="row__title">11:30 hs · Dra. Sofía Laguarda</div><div class="row__sub">Clínica del Foro</div></div>
      </div>
      <div class="minimap"><span class="minimap__pin">${I.calendar}</span></div>
    </button>
  </div>`;
};

function calDays() {
  let out = "";
  for (let d = 1; d <= 31; d++) {
    let cls = "cal__day";
    if (d === 28) cls += " is-selected";
    else if ([12, 30].includes(d)) cls += " is-mark";
    out += `<span class="${cls}">${d}</span>`;
  }
  return out;
}

ROUTES.resumen = () => `
  ${topbar({ left:`<button class="iconbtn" data-go="historia" aria-label="Volver">${I.back}</button>`, title:"Resumen para consulta" })}
